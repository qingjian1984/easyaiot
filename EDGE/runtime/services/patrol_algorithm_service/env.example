# 巡检算法服务环境变量（由 patrol_session_service 注入 PATROL_SESSION_ID / LOG_PATH）

PATROL_SESSION_ID=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iot_video
VIDEO_SERVICE_PORT=6000
GATEWAY_URL=http://localhost:48080
AI_SERVICE_URL=http://localhost:5000
JWT_TOKEN=

# 调度（也可由 PatrolSession 数据库字段驱动，此处为进程级覆盖）
PATROL_DETECT_CONF=0.25
YOLO_IMG_SIZE=416
YOLO_WORKER_THREADS=2
PATROL_CONNECT_TIMEOUT_SEC=8
PATROL_READ_WARMUP_FRAMES=3

# 拉流（与 realtime / snapshot 对齐）
AI_DECODE_USE_FFMPEG=1
AI_RTSP_ASYNC_READ=1
RTSP_OPEN_TIMEOUT_MSEC=5000
RTSP_READ_TIMEOUT_MSEC=2500

PYTHONUNBUFFERED=1
TZ=Asia/Shanghai
