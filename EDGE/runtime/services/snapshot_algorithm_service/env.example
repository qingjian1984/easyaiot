# ============================================
# 抓拍算法服务环境变量配置模板
# ============================================
# 抓拍任务不推 RTMP；cron 槽位抽帧 → 检测 → 告警/入库
# 使用方法：cp env.example .env 后按环境修改
# ============================================

# ============================================
# 基本配置（必需）
# ============================================
TASK_ID=

DATABASE_URL=postgresql://postgres:iot45722414822@localhost:5432/iot-video

VIDEO_SERVICE_PORT=6000

GATEWAY_URL=http://localhost:48080

# RTSP 传输：建议 tcp（与 realtime 一致）
# AI_RTSP_TRANSPORT=tcp

# ============================================
# GB28181 / 异步拉流（与 realtime_algorithm_service 一致）
# ============================================
# GB28181_PLAY_PROTOCOL=rtmp_first
# GB28181_HEVC_RTSP_FIRST=1
# GB28181_SERVICE_URL=http://127.0.0.1:48088/api
# AI_RTSP_ASYNC_READ=1
# AI_RTSP_ASYNC_QUEUE_MAX=30
# AI_GB28181_ASYNC_QUEUE_MAX=10
# AI_RTSP_GRAY_RECONNECT=1
# AI_RTSP_GRAY_WARMUP_SEC=15

# 抓拍专用
# SNAP_SAVE_CRON_FRAME=1
# YOLO_DETECT_CONF=0.25
# SNAPSHOT_CRON_WINDOW_SEC=5
# SNAPSHOT_RESULT_MAX_WAIT_SEC=5.0
# SNAP_CRON_SKIP_GRAY_CHECK=0

# ALERT_IMAGES_DIR=/app/alert_images

# ============================================
# 视频处理（优先 AI_* / VIEW_*）
# ============================================
SOURCE_FPS=15
TARGET_WIDTH=640
TARGET_HEIGHT=360

YOLO_IMG_SIZE=416

# ============================================
# 检测队列（cron 抽帧直投，不经抽帧器中转）
# ============================================
DETECTION_QUEUE_SIZE=20
DETECTION_KEEP_LATEST=true
# DETECTION_KEEP_LATEST_THRESHOLD=10
YOLO_WORKER_THREADS=1

PYTHONUNBUFFERED=1
TZ=Asia/Shanghai
