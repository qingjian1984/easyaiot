# ========== 唯一必配 ==========
# iot-node 控制面根地址（含端口，不要带 /admin-api 后缀也可，CLI 会规范化）
EDGE_NODE_URL=http://127.0.0.1:48080

# ========== 可选：生产加入令牌（与控制面 easyaiot.edge.join-token 一致）==========
# EDGE_JOIN_TOKEN=

# ========== 可选：AI 预览推流目标 SRS（多媒体节点时建议手动指定）==========
# 控制台「边缘节点接入」下拉选择后会生成 set-srs 命令；勿在边缘本机再装一套 SRS
# EDGE_SRS_HOST=10.0.0.20
# EDGE_SRS_RTMP_PORT=1935
# EDGE_SRS_HTTP_PORT=8080
# EDGE_SRS_API_PORT=1985

# ========== 以下均由 enroll / pull-config 自动写入 state，勿手填 ==========
# EDGE_NODE_ID=
# EDGE_AGENT_TOKEN=
# MQTT_BROKER_URLS=
# MQTT_ALGO_USERNAME=
# MQTT_ALGO_PASSWORD=
# MQTT_ALGO_CLIENT_ID=
# MQTT_ALGO_TENANT=default
# ALERT_IMAGES_DIR=/mnt/easyaiot-media/alert_images
# MEDIA_HOST_DATA_ROOT=/mnt/easyaiot-media
