# EasyAIoT 集群模式环境变量模板（VIDEO 服务）
# 用法: 复制为 .env.cluster 或合并到 .env.prod
# 前置: bash .scripts/media-cluster/enable_cluster_mode.sh

CLUSTER_MODE=true

# CephFS 共享缓冲（跨节点 DVR/抓拍/告警图）
MEDIA_HOST_DATA_ROOT=/mnt/easyaiot-media
MEDIA_RECORD_DIR=/mnt/easyaiot-media/playbacks
MEDIA_SNAP_DIR=/mnt/easyaiot-media/snaps
MEDIA_STAGING_DIR=/mnt/easyaiot-media/staging
SRS_HOST_DATA_ROOT=/mnt/easyaiot-media
SRS_RECORD_DIR=/mnt/easyaiot-media/playbacks
ALERT_IMAGES_DIR=/mnt/easyaiot-media/alert_images

# 上传流水线：kafka（推荐）| hybrid（双写迁移）| sync（单机）
MEDIA_UPLOAD_MODE=kafka
MEDIA_SNAP_UPLOAD_MODE=kafka

# 媒体节点池（iot-node 调度 SRS/ZLM）
MEDIA_NODE_POOL_ENABLED=true
MEDIA_HTTP_PLAY_HOST=
MEDIA_NODE_REGION=

# Kafka Upload Worker 依赖
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MEDIA_KAFKA_DVR_TOPIC=media.dvr.completed
MEDIA_KAFKA_SNAP_TOPIC=media.snap.completed

# MinIO 仍为权威归档（与 CephFS 物理分离）
MINIO_ENDPOINT=localhost:9000
MINIO_POOL_CONNECTIONS=32

# 远程算法/推流节点代码根（Agent 部署时使用）
NODE_REMOTE_VIDEO_ROOT=/opt/easyaiot/VIDEO
NODE_REMOTE_DEPLOY=true
