# 节点 ID（在 WEB 后台创建节点后获得）
NODE_ID=1
# Agent 令牌（创建节点时返回，或通过「重置令牌」获取）
AGENT_TOKEN=your-agent-token-here
# 控制面宿主机 Agent 设为 1，启动时从 bootstrap 同步凭据（数据库重建后自动修复 nodeId）
# 远程计算节点部署时由平台写入 PLATFORM_AGENT=0，请勿改为 1
# PLATFORM_AGENT=1
# 控制面地址（经 Gateway）
CONTROL_PLANE_URL=http://localhost:48080/admin-api/node/agent
# 心跳间隔（秒）
HEARTBEAT_INTERVAL=10
# Agent HTTP 监听
AGENT_LISTEN_HOST=0.0.0.0
AGENT_LISTEN_PORT=9100
# AI 代码根目录（远程部署模型服务）
AI_ROOT=/opt/easyaiot/AI
# VIDEO 代码根目录（远程部署算法任务）
VIDEO_ROOT=/opt/easyaiot/VIDEO
# 媒体集群脚本目录（远程部署 SRS/ZLM）
MEDIA_CLUSTER_ROOT=/opt/easyaiot/media-cluster
# MinIO（远程下载模型）
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-secret
