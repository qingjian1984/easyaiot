  {
    "id": "demo_alert_inject",
    "type": "inject",
    "z": "easyaiot_demo_alert",
    "name": "模拟告警事件",
    "props": [
      { "p": "payload" },
      { "p": "topic", "vt": "str" }
    ],
    "repeat": "",
