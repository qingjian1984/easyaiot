    ],
    "action": "",
    "property": "",
    "from": "",
    "to": "",
    "reg": false,
    "x": 980,
    "y": 180,
    "wires": [["demo_tel_debug"]]
  },
  {
    "id": "demo_tel_normal",
    "type": "change",
    "z": "easyaiot_demo_telemetry",
