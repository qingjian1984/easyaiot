  {
    "id": "demo_vision_http",
    "type": "http in",
    "z": "easyaiot_demo_vision",
    "name": "质检回调",
    "url": "/easyaiot/demo/vision/inspect",
    "method": "post",
    "upload": false,
    "swaggerDoc": "",
    "x": 180,
    "y": 160,
    "wires": [["demo_vision_parse"]]
  },
  {
    "id": "demo_vision_inject",
    "type": "inject",
    "z": "easyaiot_demo_vision",
    "name": "模拟 NG 结果",
    "props": [
      { "p": "payload" }
    ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "{\"lineId\":\"LINE-VIS-01\",\"sn\":\"SN20260723001\",\"model\":\"cover-a\",\"score\":0.42,\"label\":\"scratch\",\"pass\":false,\"camera\":\"CAM-3\"}",
    "payloadType": "json",
    "x": 180,
    "y": 260,
    "wires": [["demo_vision_parse"]]
  },
  {
    "id": "demo_vision_parse",
    "type": "function",
    "z": "easyaiot_demo_vision",
    "name": "解析 AI 质检结果",
    "func": "let body = msg.payload;\nif (typeof body === 'string') {\n    try { body = JSON.parse(body); } catch (e) {\n        msg.statusCode = 400;\n        msg.payload = { ok: false, error: 'invalid json' };\n        return [null, msg];\n    }\n}\nconst pass = !!(body && body.pass);\nconst score = Number(body && body.score);\nmsg.inspect = {\n    lineId: body.lineId,\n    sn: body.sn,\n    label: body.label || 'unknown',\n    score,\n    pass,\n    camera: body.camera,\n    judgedAt: Date.now()\n};\nmsg.payload = msg.inspect;\nif (pass) {\n    return [msg, null];\n}\nreturn [null, msg];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 440,
    "y": 200,
    "wires": [["demo_vision_ok"], ["demo_vision_ng"]]
  },
  {
    "id": "demo_vision_ok",
    "type": "change",
    "z": "easyaiot_demo_vision",
    "name": "OK：放行",
    "rules": [
      { "t": "set", "p": "command", "pt": "msg", "to": "PASS", "tot": "str" },
      { "t": "set", "p": "payload.action", "pt": "msg", "to": "conveyor_continue", "tot": "str" }
    ],
    "action": "",
    "property": "",
    "from": "",
    "to": "",
    "reg": false,
    "x": 700,
    "y": 140,
    "wires": [["demo_vision_resp", "demo_vision_debug"]]
  },
  {
    "id": "demo_vision_ng",
    "type": "change",
    "z": "easyaiot_demo_vision",
    "name": "NG：剔除联动",
    "rules": [
      { "t": "set", "p": "command", "pt": "msg", "to": "REJECT", "tot": "str" },
      { "t": "set", "p": "payload.action", "pt": "msg", "to": "rejector_pulse", "tot": "str" },
      { "t": "set", "p": "payload.holdMs", "pt": "msg", "to": "300", "tot": "num" }
    ],
    "action": "",
    "property": "",
    "from": "",
    "to": "",
    "reg": false,
    "x": 720,
    "y": 260,
    "wires": [["demo_vision_cmd", "demo_vision_resp", "demo_vision_debug"]]
  },
  {
    "id": "demo_vision_cmd",
    "type": "function",
    "z": "easyaiot_demo_vision",
    "name": "组装下发指令",
    "func": "msg.topic = 'easyaiot/demo/' + (msg.inspect.lineId || 'LINE') + '/service/invoke';\nmsg.payload = {\n    method: 'rejector_pulse',\n    params: {\n        sn: msg.inspect.sn,\n        reason: msg.inspect.label,\n        holdMs: 300\n    },\n    timestamp: Date.now()\n};\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 960,
    "y": 300,
    "wires": [["demo_vision_mqtt"]]
  },
  {
    "id": "demo_vision_mqtt",
    "type": "mqtt out",
    "z": "easyaiot_demo_vision",
    "name": "下发剔除指令",
    "topic": "",
    "qos": "1",
    "retain": "false",
    "respTopic": "",
    "contentType": "application/json",
    "userProps": "",
    "correl": "",
    "expiry": "",
    "broker": "demo_mqtt_broker",
    "x": 1180,
    "y": 300,
    "wires": []
  },
  {
    "id": "demo_vision_resp",
    "type": "function",
    "z": "easyaiot_demo_vision",
    "name": "HTTP 响应",
    "func": "if (msg.req && msg.res) {\n    msg.statusCode = 200;\n    msg.headers = { 'Content-Type': 'application/json' };\n    msg.payload = {\n        ok: true,\n        command: msg.command,\n        inspect: msg.inspect\n    };\n    return msg;\n}\nreturn null;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 960,
    "y": 160,
    "wires": [["demo_vision_http_out"]]
  },
  {
    "id": "demo_vision_http_out",
    "type": "http response",
    "z": "easyaiot_demo_vision",
    "name": "",
    "statusCode": "",
    "headers": {},
    "x": 1180,
    "y": 160,
    "wires": []
  },
  {
    "id": "demo_vision_debug",
    "type": "debug",
    "z": "easyaiot_demo_vision",
    "name": "质检判定",
    "active": true,
    "tosidebar": true,
    "console": false,
    "tostatus": true,
    "complete": "inspect",
    "targetType": "msg",
    "statusVal": "command",
    "statusType": "msg",
    "x": 960,
    "y": 220,
    "wires": []
  },

