  {
    "id": "demo_tel_mqtt_in",
    "type": "mqtt in",
    "z": "easyaiot_demo_telemetry",
    "name": "遥测订阅 /easyaiot/demo/+/telemetry",
    "topic": "easyaiot/demo/+/telemetry",
    "qos": "1",
    "datatype": "auto-detect",
    "broker": "demo_mqtt_broker",
    "nl": false,
    "rap": true,
    "rh": 0,
    "inputs": 0,
    "x": 220,
    "y": 140,
    "wires": [["demo_tel_parse"]]
  },
  {
    "id": "demo_tel_inject",
    "type": "inject",
    "z": "easyaiot_demo_telemetry",
    "name": "模拟温度上报",
    "props": [
      { "p": "payload" },
      { "p": "topic", "vt": "str" }
    ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "easyaiot/demo/GW-1001/telemetry",
    "payload": "{\"deviceId\":\"GW-1001\",\"ts\":0,\"temperature\":36.8,\"humidity\":55.2,\"online\":true}",
    "payloadType": "json",
    "x": 170,
    "y": 240,
    "wires": [["demo_tel_stamp"]]
  },
  {
    "id": "demo_tel_stamp",
    "type": "function",
    "z": "easyaiot_demo_telemetry",
    "name": "补全时间戳",
    "func": "msg.payload = msg.payload || {};\nif (!msg.payload.ts) {\n    msg.payload.ts = Date.now();\n}\nmsg.deviceId = msg.payload.deviceId || 'unknown';\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 380,
    "y": 240,
    "wires": [["demo_tel_parse"]]
  },
  {
    "id": "demo_tel_parse",
    "type": "function",
    "z": "easyaiot_demo_telemetry",
    "name": "解析遥测 JSON",
    "func": "let body = msg.payload;\nif (typeof body === 'string') {\n    try { body = JSON.parse(body); } catch (e) {\n        node.warn('遥测 JSON 解析失败: ' + e.message);\n        return null;\n    }\n}\nif (!body || typeof body !== 'object') {\n    return null;\n}\nmsg.payload = body;\nmsg.deviceId = body.deviceId || (msg.topic || '').split('/')[2] || 'unknown';\nmsg.temperature = Number(body.temperature);\nmsg.humidity = Number(body.humidity);\nmsg.metric = {\n    deviceId: msg.deviceId,\n    temperature: msg.temperature,\n    humidity: msg.humidity,\n    ts: body.ts || Date.now()\n};\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 560,
    "y": 180,
    "wires": [["demo_tel_threshold"]]
  },
  {
    "id": "demo_tel_threshold",
    "type": "switch",
    "z": "easyaiot_demo_telemetry",
    "name": "温度阈值",
    "property": "temperature",
    "propertyType": "msg",
    "rules": [
      { "t": "gte", "v": "45", "vt": "num" },
      { "t": "gte", "v": "35", "vt": "num" },
      { "t": "else" }
    ],
    "checkall": "false",
    "repair": false,
    "outputs": 3,
    "x": 760,
    "y": 180,
    "wires": [["demo_tel_high"], ["demo_tel_warn"], ["demo_tel_normal"]]
  },
  {
    "id": "demo_tel_high",
    "type": "change",
    "z": "easyaiot_demo_telemetry",
    "name": "标记：过热告警",
    "rules": [
      { "t": "set", "p": "level", "pt": "msg", "to": "critical", "tot": "str" },
      { "t": "set", "p": "payload.alert", "pt": "msg", "to": "温度过热", "tot": "str" }
    ],
    "action": "",
    "property": "",
    "from": "",
    "to": "",
    "reg": false,
    "x": 980,
    "y": 100,
    "wires": [["demo_tel_debug"]]
  },
  {
