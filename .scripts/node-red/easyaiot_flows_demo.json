    "once": false,
    "onceDelay": 0.1,
    "topic": "alert/demo",
    "payload": "{\"alarmId\":\"ALM-20260723-001\",\"deviceId\":\"PUMP-03\",\"severity\":\"振动超限\",\"severityCode\":\"VIB_HIGH\",\"severity\":2,\"value\":8.6,\"unit\":\"mm/s\"}",
    "payloadType": "json",
