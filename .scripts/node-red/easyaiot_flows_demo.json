  {
    "id": "demo_bridge_inject",
    "type": "inject",
    "z": "easyaiot_demo_bridge",
    "name": "模拟工控点位",
    "props": [
      { "p": "payload" }
    ],
    "repeat": "30",
    "crontab": "",
    "once": true,
    "onceDelay": 1,
    "topic": "",
    "payload": "{\"slaveId\":1,\"registers\":{\"40001\":1250,\"40002\":1,\"40003\":980},\"quality\":\"good\"}",
    "payloadType": "json",
    "x": 180,
    "y": 180,
    "wires": [["demo_bridge_map"]]
  },
  {
    "id": "demo_bridge_map",
    "type": "function",
    "z": "easyaiot_demo_bridge",
    "name": "点位→物模型映射",
    "func": "const regs = (msg.payload && msg.payload.registers) || {};\nconst mapped = {\n    productKey: 'easyaiot-demo-plc',\n    deviceName: 'PLC-LINE-A',\n    timestamp: Date.now(),\n    properties: {\n        speed_rpm: Number(regs['40001'] || 0),\n        motor_run: Number(regs['40002'] || 0) === 1,\n        pressure_kpa: Number(regs['40003'] || 0) / 10,\n        quality: (msg.payload && msg.payload.quality) || 'unknown'\n    }\n};\nmsg.payload = mapped;\nmsg.topic = 'easyaiot/demo/PLC-LINE-A/property/post';\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 180,
    "wires": [["demo_bridge_filter", "demo_bridge_debug"]]
  },
  {
    "id": "demo_bridge_filter",
    "type": "switch",
    "z": "easyaiot_demo_bridge",
    "name": "仅上行 good",
    "property": "payload.properties.quality",
    "propertyType": "msg",
    "rules": [
      { "t": "eq", "v": "good", "vt": "str" }
    ],
    "checkall": "true",
    "repair": false,
    "outputs": 1,
    "x": 660,
    "y": 140,
    "wires": [["demo_bridge_mqtt_out"]]
  },
  {
    "id": "demo_bridge_mqtt_out",
    "type": "mqtt out",
    "z": "easyaiot_demo_bridge",
    "name": "MQTT 物模型上报",
    "topic": "",
    "qos": "1",
    "retain": "false",
    "respTopic": "",
    "contentType": "application/json",
    "userProps": "",
    "correl": "",
    "expiry": "",
    "broker": "demo_mqtt_broker",
    "x": 900,
    "y": 140,
    "wires": []
  },
  {
    "id": "demo_bridge_debug",
