  {
    "id": "demo_alert_inject_crit",
    "type": "inject",
    "z": "easyaiot_demo_alert",
    "name": "模拟紧急告警",
    "props": [
      { "p": "payload" }
    ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "{\"alarmId\":\"ALM-20260723-002\",\"deviceId\":\"XFMR-01\",\"severity\":\"绕组温度过高\",\"severityCode\":\"TEMP_CRIT\",\"severity\":1,\"value\":98.5,\"unit\":\"℃\"}",
    "payloadType": "json",
    "x": 180,
    "y": 240,
    "wires": [["demo_alert_normalize"]]
  },
  {
    "id": "demo_alert_normalize",
    "type": "function",
    "z": "easyaiot_demo_alert",
    "name": "规范化告警",
    "func": "const p = msg.payload || {};\nconst severity = Number(p.severity || 3);\nconst levelMap = {1: '紧急', 2: '重要', 3: '一般'};\nmsg.severity = severity;\nmsg.levelName = levelMap[severity] || '一般';\nmsg.payload = {\n    ...p,\n    severity,\n    levelName: msg.levelName,\n    receivedAt: Date.now(),\n    source: 'EasyAIoT-Demo'\n};\nmsg.channels = severity === 1\n    ? ['sms', 'voice', 'webhook']\n    : (severity === 2 ? ['webhook', 'app'] : ['app']);\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 420,
    "y": 200,
    "wires": [["demo_alert_switch"]]
  },
  {
    "id": "demo_alert_switch",
    "type": "switch",
    "z": "easyaiot_demo_alert",
    "name": "按级别分流",
    "property": "severity",
    "propertyType": "msg",
    "rules": [
      { "t": "eq", "v": "1", "vt": "num" },
      { "t": "eq", "v": "2", "vt": "num" },
      { "t": "else" }
    ],
    "checkall": "false",
    "repair": false,
    "outputs": 3,
    "x": 620,
    "y": 200,
    "wires": [["demo_alert_urgent"], ["demo_alert_major"], ["demo_alert_minor"]]
  },
  {
    "id": "demo_alert_urgent",
    "type": "template",
    "z": "easyaiot_demo_alert",
    "name": "紧急通知模板",
    "field": "payload",
    "fieldType": "msg",
    "format": "handlebars",
    "syntax": "mustache",
    "template": "[紧急] {{payload.deviceId}} {{payload.severity}}={{payload.value}}{{payload.unit}}，请立即处置。通道: {{channels}}",
    "output": "str",
    "x": 860,
    "y": 120,
    "wires": [["demo_alert_debug"]]
  },
  {
    "id": "demo_alert_major",
    "type": "template",
