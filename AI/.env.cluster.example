# EasyAIoT 集群模式环境变量模板（AI 服务）
# 用法: 复制为 .env.cluster 或合并到 .env.prod
# 前置: bash .scripts/media-cluster/enable_cluster_mode.sh

CLUSTER_MODE=true

# CephFS 共享数据（跨节点训练/推理模型缓存）
MEDIA_HOST_DATA_ROOT=/mnt/easyaiot-media
AI_DATASETS_DIR=/mnt/easyaiot-media/ai/datasets
AI_MODELS_DIR=/mnt/easyaiot-media/ai/models

# MinIO 权威归档（模型/数据集长期存储）
MINIO_ENDPOINT=localhost:9000

# 远程推理节点
NODE_REMOTE_AI_ROOT=/opt/easyaiot/AI
NODE_REMOTE_DEPLOY=true

# Kafka / Nacos 等中间件（按实际集群地址修改）
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NACOS_SERVER=localhost:8848
